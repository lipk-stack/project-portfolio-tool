NODE_ENV=development
PORT=3001
JWT_SECRET=change-this-secret-in-production-to-a-long-random-string
DB_PATH=./data/portfolio.db
CORS_ORIGIN=http://localhost:5173

# Email notifications (optional — leave SMTP_HOST empty to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ProjectPulse <noreply@example.com>
# Base URL used in email links
APP_URL=http://localhost:3001
